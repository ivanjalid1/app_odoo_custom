<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Pestaña SUNAT/EDI desactivada — cliente decidió no usar facturación
         electrónica integrada (Nubefact cobra por comprobante).
         El modelo invoice_edi.py se mantiene activo para preservar los campos
         en account.move. La vista queda inactiva para no mostrar la pestaña. -->
    <record id="view_move_edi_form" model="ir.ui.view">
        <field name="name">account.move.edi.form</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="active" eval="False"/>
        <field name="arch" type="xml">
            <notebook position="inside">
                <page string="SUNAT / EDI" invisible="1"/>
            </notebook>
        </field>
    </record>

</odoo>
