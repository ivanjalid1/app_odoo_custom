<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Reubicar items contables del submenu "Configuración → Contabilidad"
         al top-level "Contabilidad" para que queden junto a Asientos/Apuntes
         (el contador no tiene que buscar entre dos menús con el mismo nombre). -->

    <record id="account.menu_action_account_form" model="ir.ui.menu">
        <field name="parent_id" ref="account.menu_finance_entries"/>
        <field name="sequence">5</field>
    </record>

    <record id="account.menu_action_account_journal_form" model="ir.ui.menu">
        <field name="parent_id" ref="account.menu_finance_entries"/>
        <field name="sequence">40</field>
    </record>

    <record id="account.menu_action_tax_form" model="ir.ui.menu">
        <field name="parent_id" ref="account.menu_finance_entries"/>
        <field name="sequence">50</field>
    </record>

    <record id="account.menu_action_tax_group" model="ir.ui.menu">
        <field name="parent_id" ref="account.menu_finance_entries"/>
        <field name="sequence">51</field>
    </record>

    <record id="account.menu_action_account_fiscal_position_form" model="ir.ui.menu">
        <field name="parent_id" ref="account.menu_finance_entries"/>
        <field name="sequence">60</field>
    </record>

    <record id="account.menu_action_currency_form" model="ir.ui.menu">
        <field name="parent_id" ref="account.menu_finance_entries"/>
        <field name="sequence">70</field>
    </record>

    <!-- Cuentas bancarias (estaban en Contactos → Config; las llevamos a Facturación) -->
    <record id="contacts.menu_config_bank_accounts" model="ir.ui.menu">
        <field name="parent_id" ref="account.menu_finance_entries"/>
        <field name="sequence">75</field>
    </record>

    <!-- Proteger asientos: reubicar junto a los demás ítems de asientos,
         para que no parezca hijo de "Cuentas bancarias" en la UI -->
    <record id="account.menu_action_secure_entries" model="ir.ui.menu">
        <field name="parent_id" ref="account.menu_finance_entries"/>
        <field name="sequence">15</field>
    </record>

</odoo>
