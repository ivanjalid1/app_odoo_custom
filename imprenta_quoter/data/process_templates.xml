<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="process_guill_ini" model="impr.process.template">
            <field name="name">Guillotina — Corte inicial</field>
            <field name="code">GUILL_INI</field>
            <field name="sequence">10</field>
        </record>

        <record id="process_offset" model="impr.process.template">
            <field name="name">Impresión Offset</field>
            <field name="code">OFFSET</field>
            <field name="sequence">20</field>
        </record>

        <record id="process_dobla" model="impr.process.template">
            <field name="name">Doblado</field>
            <field name="code">DOBLA</field>
            <field name="sequence">30</field>
        </record>

        <record id="process_alce" model="impr.process.template">
            <field name="name">Encartado / Alce</field>
            <field name="code">ALCE</field>
            <field name="sequence">40</field>
        </record>

        <record id="process_cosido" model="impr.process.template">
            <field name="name">Cosido</field>
            <field name="code">COSIDO</field>
            <field name="sequence">50</field>
        </record>

        <record id="process_hotmelt" model="impr.process.template">
            <field name="name">Hot Melt</field>
            <field name="code">HOTMELT</field>
            <field name="sequence">60</field>
        </record>

        <record id="process_barniz_uv" model="impr.process.template">
            <field name="name">Barniz UV Brillo</field>
            <field name="code">BARNIZ_UV</field>
            <field name="sequence">70</field>
        </record>

        <record id="process_barniz_ac" model="impr.process.template">
            <field name="name">Barniz Acrílico</field>
            <field name="code">BARNIZ_AC</field>
            <field name="sequence">75</field>
        </record>

        <record id="process_plast" model="impr.process.template">
            <field name="name">Plastificado</field>
            <field name="code">PLAST</field>
            <field name="sequence">80</field>
        </record>

        <record id="process_guill_fin" model="impr.process.template">
            <field name="name">Corte Final</field>
            <field name="code">GUILL_FIN</field>
            <field name="sequence">90</field>
        </record>

        <record id="process_tercero" model="impr.process.template">
            <field name="name">Servicios de Terceros</field>
            <field name="code">TERCERO</field>
            <field name="sequence">100</field>
        </record>

        <record id="process_despacho" model="impr.process.template">
            <field name="name">Empaque y Despacho</field>
            <field name="code">DESPACHO</field>
            <field name="sequence">110</field>
        </record>

    </data>

    <!-- Vincular work centers a plantillas (noupdate="0" para que se aplique en -u) -->
    <data noupdate="0">
        <record id="process_guill_ini" model="impr.process.template">
            <field name="workcenter_id" ref="workcenter_guillotina"/>
            <field name="people_default">1</field>
            <field name="duration_days_default">1</field>
        </record>
        <record id="process_offset" model="impr.process.template">
            <field name="workcenter_id" ref="workcenter_offset"/>
            <field name="people_default">2</field>
            <field name="duration_days_default">1</field>
        </record>
        <record id="process_dobla" model="impr.process.template">
            <field name="workcenter_id" ref="workcenter_dobladora"/>
            <field name="people_default">1</field>
            <field name="duration_days_default">1</field>
        </record>
        <record id="process_alce" model="impr.process.template">
            <field name="workcenter_id" ref="workcenter_encartadora"/>
            <field name="people_default">2</field>
            <field name="duration_days_default">1</field>
        </record>
        <record id="process_cosido" model="impr.process.template">
            <field name="workcenter_id" ref="workcenter_cosedora"/>
            <field name="people_default">1</field>
            <field name="duration_days_default">1</field>
        </record>
        <record id="process_hotmelt" model="impr.process.template">
            <field name="workcenter_id" ref="workcenter_acabado"/>
            <field name="people_default">1</field>
            <field name="duration_days_default">1</field>
        </record>
        <record id="process_barniz_uv" model="impr.process.template">
            <field name="workcenter_id" ref="workcenter_acabado"/>
            <field name="people_default">1</field>
            <field name="duration_days_default">1</field>
        </record>
        <record id="process_barniz_ac" model="impr.process.template">
            <field name="workcenter_id" ref="workcenter_acabado"/>
            <field name="people_default">1</field>
            <field name="duration_days_default">1</field>
        </record>
        <record id="process_plast" model="impr.process.template">
            <field name="workcenter_id" ref="workcenter_acabado"/>
            <field name="people_default">1</field>
            <field name="duration_days_default">1</field>
        </record>
        <record id="process_guill_fin" model="impr.process.template">
            <field name="workcenter_id" ref="workcenter_guillotina"/>
            <field name="people_default">1</field>
            <field name="duration_days_default">1</field>
        </record>
        <record id="process_despacho" model="impr.process.template">
            <field name="workcenter_id" ref="workcenter_acabado"/>
            <field name="people_default">2</field>
            <field name="duration_days_default">1</field>
        </record>
    </data>
</odoo>
