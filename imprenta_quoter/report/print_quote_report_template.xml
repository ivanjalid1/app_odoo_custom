<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="report_print_quote">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-set="company" t-value="env.company"/>
                <t t-call="web.external_layout">
                    <div class="page" style="font-family: Arial, sans-serif; font-size: 12px;">

                        <!-- ENCABEZADO -->
                        <div class="row mb-3" style="border-bottom: 3px solid #1a5276; padding-bottom: 12px;">
                            <div class="col-6" style="display: flex; align-items: flex-start; gap: 12px;">
                                <div>
                                    <img t-att-src="'/web/image/res.company/%s/logo' % company.id"
                                         style="max-height: 80px; max-width: 200px;"/>
                                </div>
                                <div style="margin-top: 4px;">
                                    <div style="font-size: 14px; font-weight: bold; color: #1a5276;">
                                        <span t-esc="company.name"/>
                                    </div>
                                    <t t-if="company.street">
                                        <div style="font-size: 10px; color: #555;">
                                            <span t-esc="company.street"/>
                                            <t t-if="company.city">, <span t-esc="company.city"/></t>
                                        </div>
                                    </t>
                                    <t t-if="company.vat">
                                        <div style="font-size: 10px; color: #555;">
                                            RUC: <span t-esc="company.vat"/>
                                        </div>
                                    </t>
                                </div>
                            </div>
                            <div class="col-6 text-end">
                                <div style="font-size: 22px; font-weight: bold; color: #1a5276;">
                                    <span t-esc="doc.name"/>
                                </div>
                                <div style="font-size: 11px; color: #555; margin-top: 4px;">
                                    <strong>Fecha:</strong>&#160;<span t-field="doc.date"/>
                                </div>
                                <div style="font-size: 11px; color: #555;">
                                    <strong>T.C.:</strong>&#160;S/&#160;<span t-esc="'%.2f' % doc.tc"/>
                                </div>
                            </div>
                        </div>

                        <!-- DATOS DEL CLIENTE -->
                        <div class="row mb-3 p-2" style="background: #f8f9fa; border-radius: 4px;">
                            <div class="col-12">
                                <strong>Cliente:</strong>&#160;
                                <span t-esc="doc.client_id.name if doc.client_id else '&#8212;'"/>
                                <t t-if="doc.client_id.vat">
                                    &#160;|&#160;<strong>RUC:</strong>&#160;
                                    <span t-esc="doc.client_id.vat"/>
                                </t>
                                <t t-if="doc.nombre">
                                    &#160;|&#160;<strong>Trabajo:</strong>&#160;
                                    <span t-esc="doc.nombre"/>
                                </t>
                            </div>
                        </div>

                        <!-- ESPECIFICACIONES -->
                        <h5 style="color: #1a5276; border-bottom: 2px solid #1a5276; padding-bottom: 4px;">
                            Especificaciones
                        </h5>
                        <table class="table table-sm table-bordered" style="font-size: 11px;">
                            <tr>
                                <td style="width:25%; background:#f8f9fa;"><strong>Formato</strong></td>
                                <td><span t-esc="doc.ancho"/>&#160;&#215;&#160;<span t-esc="doc.largo"/>&#160;cm</td>
                                <td style="width:25%; background:#f8f9fa;"><strong>Tiraje</strong></td>
                                <td><span t-esc="doc.tiraje_principal"/>&#160;ejemplares</td>
                            </tr>
                            <tr>
                                <td style="background:#f8f9fa;"><strong>P&#225;ginas</strong></td>
                                <td><span t-esc="doc.paginas_total"/></td>
                                <td style="background:#f8f9fa;"><strong>Peso x libro</strong></td>
                                <td><span t-esc="'%.2f' % doc.peso_x_libro"/>&#160;kg</td>
                            </tr>
                        </table>

                        <!-- DETALLE DE COSTOS -->
                        <h5 style="color: #1a5276; border-bottom: 2px solid #1a5276; padding-bottom: 4px; margin-top: 16px;">
                            Detalle de costos
                        </h5>
                        <table class="table table-sm" style="font-size: 11px;">
                            <thead style="background: #1a5276; color: white;">
                                <tr>
                                    <th>Concepto</th>
                                    <th class="text-end">Subtotal (S/)</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-if="doc.total_papeles">
                                    <tr><td>Papeles</td><td class="text-end"><span t-esc="'%.2f' % doc.total_papeles"/></td></tr>
                                </t>
                                <t t-if="doc.total_placas">
                                    <tr style="background:#f8f9fa;"><td>Placas</td><td class="text-end"><span t-esc="'%.2f' % doc.total_placas"/></td></tr>
                                </t>
                                <t t-if="doc.total_offset">
                                    <tr><td>Offset</td><td class="text-end"><span t-esc="'%.2f' % doc.total_offset"/></td></tr>
                                </t>
                                <t t-if="doc.total_acabados">
                                    <tr style="background:#f8f9fa;"><td>Acabados car&#225;tula</td><td class="text-end"><span t-esc="'%.2f' % doc.total_acabados"/></td></tr>
                                </t>
                                <t t-if="doc.total_doblado">
                                    <tr><td>Doblado</td><td class="text-end"><span t-esc="'%.2f' % doc.total_doblado"/></td></tr>
                                </t>
                                <t t-if="doc.total_alce">
                                    <tr style="background:#f8f9fa;"><td>Alce / Encartado</td><td class="text-end"><span t-esc="'%.2f' % doc.total_alce"/></td></tr>
                                </t>
                                <t t-if="doc.total_cosido">
                                    <tr><td>Cosido</td><td class="text-end"><span t-esc="'%.2f' % doc.total_cosido"/></td></tr>
                                </t>
                                <t t-if="doc.total_troquelado">
                                    <tr style="background:#f8f9fa;"><td>Troquelado</td><td class="text-end"><span t-esc="'%.2f' % doc.total_troquelado"/></td></tr>
                                </t>
                                <t t-if="doc.total_encuadernado">
                                    <tr><td>Encuadernado</td><td class="text-end"><span t-esc="'%.2f' % doc.total_encuadernado"/></td></tr>
                                </t>
                                <t t-if="doc.total_cortes">
                                    <tr style="background:#f8f9fa;"><td>Cortes</td><td class="text-end"><span t-esc="'%.2f' % doc.total_cortes"/></td></tr>
                                </t>
                                <t t-if="doc.total_empaquetado">
                                    <tr><td>Empaquetado</td><td class="text-end"><span t-esc="'%.2f' % doc.total_empaquetado"/></td></tr>
                                </t>
                                <t t-if="doc.total_transporte">
                                    <tr style="background:#f8f9fa;"><td>Transporte</td><td class="text-end"><span t-esc="'%.2f' % doc.total_transporte"/></td></tr>
                                </t>
                            </tbody>
                            <tfoot>
                                <tr style="border-top: 2px solid #1a5276;">
                                    <td style="font-weight: bold;">Subtotal costos</td>
                                    <td class="text-end" style="font-weight: bold;">
                                        S/&#160;<span t-esc="'%.2f' % doc.precio_total"/>
                                    </td>
                                </tr>
                            </tfoot>
                        </table>

                        <!-- GGFF / UTILIDAD / COMISION -->
                        <table class="table table-sm" style="font-size: 11px; margin-top: -8px;">
                            <tbody>
                                <tr>
                                    <td>GGFF (<span t-esc="doc.pct_ggff"/>%)</td>
                                    <td class="text-end"><span t-esc="'%.2f' % doc.ggff"/></td>
                                </tr>
                                <tr style="background:#f8f9fa;">
                                    <td style="padding-left: 20px; color: #666;">Total post GGFF</td>
                                    <td class="text-end" style="color: #666;"><span t-esc="'%.2f' % doc.base_post_ggff"/></td>
                                </tr>
                                <tr>
                                    <td>Utilidad (<span t-esc="doc.pct_utilidad"/>%)</td>
                                    <td class="text-end"><span t-esc="'%.2f' % doc.utilidad"/></td>
                                </tr>
                                <tr style="background:#f8f9fa;">
                                    <td style="padding-left: 20px; color: #666;">Total post Utilidad</td>
                                    <td class="text-end" style="color: #666;"><span t-esc="'%.2f' % doc.base_post_utilidad"/></td>
                                </tr>
                                <tr>
                                    <td>Comisi&#243;n ventas (<span t-esc="doc.pct_comision"/>%)</td>
                                    <td class="text-end"><span t-esc="'%.2f' % doc.comision"/></td>
                                </tr>
                            </tbody>
                        </table>

                        <!-- PRECIO FINAL -->
                        <table class="table table-sm" style="font-size: 13px; margin-top: -8px;">
                            <tr style="background: #1a5276; color: white;">
                                <td style="font-weight: bold; padding: 8px;">PRECIO FINAL sin IGV</td>
                                <td class="text-end" style="font-weight: bold; padding: 8px;">
                                    S/&#160;<span t-esc="'%.2f' % doc.precio_final"/>
                                </td>
                            </tr>
                            <tr style="background: #d4edda;">
                                <td style="font-weight: bold; padding: 8px;">PRECIO FINAL con IGV (18%)</td>
                                <td class="text-end" style="font-weight: bold; padding: 8px;">
                                    S/&#160;<span t-esc="'%.2f' % doc.precio_final_con_igv"/>
                                </td>
                            </tr>
                            <t t-if="doc.tiraje_principal">
                                <tr style="background: #ecf0f1;">
                                    <td>Precio unitario sin IGV (&#215;&#160;<span t-esc="doc.tiraje_principal"/>&#160;ejm.)</td>
                                    <td class="text-end">S/&#160;<span t-esc="'%.2f' % doc.precio_unitario"/></td>
                                </tr>
                                <tr style="background: #ecf0f1;">
                                    <td>Precio unitario con IGV</td>
                                    <td class="text-end">S/&#160;<span t-esc="'%.2f' % doc.precio_unitario_con_igv"/></td>
                                </tr>
                            </t>
                        </table>

                        <!-- OTRAS OPCIONES DE TIRAJE -->
                        <t t-if="doc.tiraje_ids">
                            <h5 style="color: #1a5276; border-bottom: 2px solid #1a5276; padding-bottom: 4px; margin-top: 16px;">
                                Otras opciones de tiraje
                            </h5>
                            <table class="table table-sm table-bordered" style="font-size: 11px;">
                                <thead style="background: #1a5276; color: white;">
                                    <tr>
                                        <th class="text-end">Tiraje</th>
                                        <th class="text-end">Utilidad %</th>
                                        <th class="text-end">Precio s/IGV</th>
                                        <th class="text-end">P. Unit. s/IGV</th>
                                        <th class="text-end">Precio c/IGV</th>
                                        <th class="text-end">P. Unit. c/IGV</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="doc.tiraje_ids" t-as="alt">
                                        <tr t-att-style="'background: #f8f9fa;' if alt_index % 2 else ''">
                                            <td class="text-end" style="font-weight: bold;">
                                                <span t-esc="alt.tiraje"/>&#160;ejm.
                                            </td>
                                            <td class="text-end"><span t-esc="'%.1f' % alt.pct_utilidad"/>%</td>
                                            <td class="text-end">S/&#160;<span t-esc="'%.2f' % alt.precio_total"/></td>
                                            <td class="text-end">S/&#160;<span t-esc="'%.4f' % alt.precio_unitario"/></td>
                                            <td class="text-end" style="font-weight: bold; color: #1a5276;">
                                                S/&#160;<span t-esc="'%.2f' % alt.precio_total_igv"/>
                                            </td>
                                            <td class="text-end">S/&#160;<span t-esc="'%.4f' % alt.precio_unitario_igv"/></td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </t>

                        <!-- NOTA -->
                        <div class="mt-3 p-2" style="border: 1px solid #ddd; border-radius: 4px; font-size: 10px; color: #666;">
                            <strong>Nota:</strong> Esta cotizaci&#243;n tiene validez de 30 d&#237;as a partir
                            de la fecha de emisi&#243;n. Los precios est&#225;n sujetos a variaci&#243;n en el costo
                            de materiales.
                            <t t-if="doc.nota">
                                <br/><strong>Observaciones:</strong>&#160;<span t-esc="doc.nota"/>
                            </t>
                        </div>

                    </div>
                </t>
            </t>
        </t>
    </template>

</odoo>
